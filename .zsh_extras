# ~/.zsh_extras — autocomplete, reverse search, and prompt theme

# ── fzf ───────────────────────────────────────────────────────────────────────
export FZF_DEFAULT_OPTS="
    --color=bg+:#1e2a3a,bg:#0d1117,spinner:#58a6ff,hl:#58a6ff
    --color=fg:#c9d1d9,header:#58a6ff,info:#3fb950,pointer:#58a6ff
    --color=marker:#3fb950,fg+:#e6edf3,prompt:#58a6ff,hl+:#58a6ff
    --height=40% --layout=reverse --border=rounded
    --bind 'ctrl-/:toggle-preview'
"
export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window=down:3:wrap"

# ── Prompt Theme (dark, no framework) ────────────────────────────────────────
zstyle ':vcs_info:git:*' formats       ' %F{#f0883e}(%b)%f'
zstyle ':vcs_info:git:*' actionformats ' %F{#f85149}(%b|%a)%f'

typeset -g _vcs_msg=""

# Read result written by background job, then redraw prompt
TRAPUSR1() {
    local tmp="${TMPDIR:-/tmp}/.zvcs_$$"
    [[ -f $tmp ]] && { _vcs_msg=$(<"$tmp"); rm -f "$tmp" }
    zle && zle reset-prompt
}

_vcs_async_precmd() {
    { vcs_info; print -rn "$vcs_info_msg_0_" >! "${TMPDIR:-/tmp}/.zvcs_$$"; kill -USR1 $$ } &!
}

add-zsh-hook precmd _vcs_async_precmd

# Colors
_p_user='%F{#3fb950}%n%f'          # green   — username
_p_host='%F{#58a6ff}%m%f'          # blue    — hostname
_p_dir='%F{#79c0ff}%~%f'           # lt-blue — current path
_p_status='%(?.%F{#3fb950}❯%f.%F{#f85149}❯%f)'  # green/red chevron

PROMPT='
%F{#30363d}┌─[%f${_p_user}%F{#30363d}@%f${_p_host}%F{#30363d}]%f ${_p_dir}${_vcs_msg}
%F{#30363d}└─%f${_p_status} '

RPROMPT='%F{#8b949e}%D{%H:%M}%f'   # grey clock on the right
